#!/bin/sh
# Full smoke before pushing. ~25–40 seconds total.
# Blocks the push if anything is broken — TS errors, build failures, unit tests, or tracked secrets.
# DB-backed integration tests and Playwright e2e are NOT in this hook on purpose
# (they need a live PostgreSQL / browser binaries). They run in CI.
set -e

echo "🔍 Pre-push smoke tests..."

echo "  → Backend typecheck"
npm run typecheck

echo "  → Backend build"
npm run build

echo "  → Backend unit tests"
npm run test:unit

echo "  → Webapp typecheck"
( cd webapp && npm run typecheck )

echo "  → Webapp build"
( cd webapp && npm run build )

echo "  → Tracked-secret scan"
SECRET_PATTERN='(^|/)\.env(\.local|\.deploy)?$|\.pem$|\.key$|deploy_key'
SECRETS=$(git ls-files | grep -E "$SECRET_PATTERN" || true)
if [ -n "$SECRETS" ]; then
  echo ""
  echo "  ❌ Secret files are tracked in git:"
  echo "$SECRETS" | sed 's/^/     /'
  echo "  Untrack them with: git rm --cached <file> && git commit -m 'untrack secrets'"
  exit 1
fi

echo "✅ Pre-push smoke passed"
