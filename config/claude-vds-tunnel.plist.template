<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.claude-vds.tunnel</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-c</string>
    <string>source PROJECT_ROOT/.env.local 2>/dev/null; export RUN_FOREGROUND=1; exec PROJECT_ROOT/scripts/claude-vds-tunnel.sh --foreground</string>
  </array>
  <key>WorkingDirectory</key>
  <string>PROJECT_ROOT</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/claude-vds-tunnel.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/claude-vds-tunnel.err</string>
</dict>
</plist>
