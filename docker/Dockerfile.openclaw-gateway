# Minimal OpenClaw Gateway for chat completions only (Node 22 + openclaw).
# Config is mounted at runtime; token from env OPENCLAW_GATEWAY_TOKEN.
FROM node:22-alpine

RUN npm install -g openclaw@latest

# Default state dir for OpenClaw (config mounted by compose).
RUN mkdir -p /home/node/.openclaw && chown -R node:node /home/node/.openclaw

USER node
WORKDIR /home/node

ENV OPENCLAW_STATE_DIR=/home/node/.openclaw

CMD ["openclaw", "gateway"]
