# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_@BotFather

# Google OAuth2 (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
# Required for calendar linking: HTTPS URL where Google redirects after sign-in.
# Add this exact URL to Google Console → Credentials → OAuth 2.0 Client → Authorized redirect URIs.
# Domain and SSL are managed by Dokploy/Traefik — just set the URL with your domain.
# OAUTH_REDIRECT_URI=https://your-domain.com/oauth/callback

# Voice → calendar: transcription + extraction via OpenRouter. https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key

# Admin Telegram user ID (for broadcast via voice). Get it from @userinfobot.
# ADMIN_TELEGRAM_ID=123456789

# Allowed user IDs (comma-separated). If set, only these users can use the bot.
# ALLOWED_USER_IDS=123456789,987654321

# PostgreSQL connection string for expense tracking
# DATABASE_URL=postgresql://bot:changeme@localhost:5432/expenses_bot

# Monthly expense limit in rubles (default: 350000)
# MONTHLY_EXPENSE_LIMIT=350000

# Default bot mode: "calendar", "expenses", or "transcribe" (default: calendar)
# DEFAULT_BOT_MODE=calendar

# Redis connection for voice transcription queue (enables /transcribe mode)
# REDIS_URL=redis://localhost:6379

# Docker:
# DB_PASSWORD=changeme

# HTTP server port (default: 18790). Dokploy/Traefik proxies HTTPS to this port.
# PORT=18790

# Mini App URL for Telegram menu button and addToHomeScreen().
# Set WEBAPP_URL to your public HTTPS domain (e.g. https://your-domain.com/).
# Without this, the "Add to Home Screen" button in Mini App will not work.
# WEBAPP_URL=https://your-domain.com/

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# Telegram Parser — MTProto user account for channel reading (enables /digest mode)
# Get api_id and api_hash from https://my.telegram.org/apps
# Use a DEDICATED phone number, not your primary Telegram account
# TELEGRAM_PARSER_API_ID=12345
# TELEGRAM_PARSER_API_HASH=abcdef1234567890abcdef1234567890

# Digest cron schedule (default: "0 6 * * *" = daily at 6:00 Moscow time)
# DIGEST_CRON=0 6 * * *

# Max total tracked channels across all users (default: 100)
# DIGEST_MAX_CHANNELS_TOTAL=100

# Proxy for Telegram API (if Telegram is blocked/throttled)
# Supports: socks5://host:port, socks5://user:pass@host:port, http://host:port
# TELEGRAM_PROXY=socks5://127.0.0.1:1080

# OSINT search via Tavily API (enables /osint command). https://tavily.com/
# TAVILY_API_KEY=tvly-xxx

# OpenTelemetry — OTLP exporter endpoint (enables tracing when set)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=sovetnik-bot
