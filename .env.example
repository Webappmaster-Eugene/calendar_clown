# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_@BotFather

# Google OAuth2 (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
# Required for calendar linking: HTTPS URL where Google redirects after sign-in.
# Add this exact URL to Google Console → Credentials → OAuth 2.0 Client → Authorized redirect URIs.
# Domain and SSL are managed by Dokploy/Traefik — just set the URL with your domain.
# OAUTH_REDIRECT_URI=https://your-domain.com/oauth/callback

# Voice → calendar: transcription + extraction via OpenRouter. https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key

# Admin Telegram user ID (for broadcast via voice). Get it from @userinfobot.
# ADMIN_TELEGRAM_ID=123456789

# HTTP server port (default: 18790). Dokploy/Traefik proxies HTTPS to this port.
# PORT=18790
