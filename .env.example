# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_@BotFather

# Google OAuth2 (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Path to Google token file (optional; default: ./data/token.json)
# GOOGLE_TOKEN_PATH=./data/token.json

# Voice → calendar (optional): transcription + extraction via OpenRouter. https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key

# Trusted admins: Telegram user IDs (comma-separated) who can use /send to message users by username
# ADMIN_USER_IDS=714820789

# Send message API (optional): OpenClaw can send messages to users by username. See docs/USAGE_AND_ARCHITECTURE.md
# SEND_MESSAGE_API_KEY=secret_bearer_token
# SEND_MESSAGE_API_PORT=18790
# SEND_MESSAGE_API_HOST=127.0.0.1
# USER_CHATS_PATH=./data/user_chats.json

# Postgres: хранение сообщений и транскриптов голоса (опционально). См. docker-compose.yml и README.
# DATABASE_URL=postgresql://bot:bot@localhost:5432/bot
# или: POSTGRES_HOST=localhost POSTGRES_PORT=5432 POSTGRES_USER=bot POSTGRES_PASSWORD=bot POSTGRES_DB=bot
