# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_@BotFather

# Google OAuth2 (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Path to Google token file (optional; default: ./data/token.json)
# GOOGLE_TOKEN_PATH=./data/token.json

# Voice → calendar (optional): send voice message to create events
# Groq Whisper for transcription: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key

# OpenRouter: one task — extract calendar event from transcript (DeepSeek). https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key
