# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_@BotFather

# Google OAuth2 (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
# Required for calendar linking: HTTPS URL where Google redirects after sign-in. Add this exact URL to Google Console → Credentials → OAuth 2.0 Client → Authorized redirect URIs.
# OAUTH_REDIRECT_URI=https://oauth.podbor-minuta.ru/oauth/callback

# Path to Google token file (optional; default: ./data/token.json)
# GOOGLE_TOKEN_PATH=./data/token.json

# Voice → calendar (optional): transcription + extraction via OpenRouter. https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key

# Let's Encrypt email for SSL certificate (used by scripts/ensure-oauth-ssl.sh on first deploy)
# CERTBOT_EMAIL=your@email.com
