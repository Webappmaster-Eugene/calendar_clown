{
  "name": "telegram-google-calendar-bot",
  "version": "1.0.0",
  "description": "Telegram bot for Google Calendar meetings",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "authorize": "tsx scripts/authorize.ts",
    "tg-auth": "tsx scripts/tg-auth.ts",
    "test": "tsx --test tests/*.test.ts",
    "test:parser": "tsx --test tests/parser.test.ts",
    "test:repo": "tsx --test tests/repository.test.ts",
    "import-birthdays": "tsx src/notable-dates/importCsv.ts",
    "typecheck": "tsc --noEmit",
    "smoke": "npm run build && npm run typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky || true"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "bullmq": "^5.34.0",
    "chrono-node": "^2.7.4",
    "croner": "^10.0.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "exceljs": "^4.4.0",
    "google-auth-library": "^9.14.1",
    "googleapis": "^144.0.0",
    "https-proxy-agent": "^8.0.0",
    "ioredis": "^5.4.0",
    "pg": "^8.20.0",
    "socks-proxy-agent": "^9.0.0",
    "telegraf": "^4.16.3",
    "telegram": "^2.26.22"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "husky": "^9.1.7",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
